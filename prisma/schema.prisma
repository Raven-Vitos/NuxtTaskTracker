generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  tasks    Task[]
}

model Task {
  id        String   @id @default(uuid())
  title     String
  status    String   @default("todo")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}